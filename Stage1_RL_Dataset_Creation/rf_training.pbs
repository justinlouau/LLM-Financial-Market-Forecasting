#!/bin/bash
#PBS -l select=1:ncpus=4:mem=64gb:ngpus=1:gpu_model=H200
#PBS -l walltime=12:00:00
#PBS -m ae
#PBS -j oe

# Usage:
#   - Submit job: qsub rf_training.pbs

cd $PBS_O_WORKDIR

# Load required modules
module load python/3.11.3
module load cuda/12.8.0
module load gcc/12.2.0

source /home/.venv/bin/activate

# --- CORE FIX: Set Cache Directory Before Running Anything ---
# Define the cache path in your scratch directory
CACHE_DIR=$TMPDIR/hf_cache
mkdir -p $CACHE_DIR # Ensure the directory exists

# Export the environment variables. This forces all subsequent processes
# to use this path for caching.
export HF_HUB_ENABLE_HF_TRANSFER=1
export HF_HOME=$CACHE_DIR
export HUGGINGFACE_HUB_CACHE=$CACHE_DIR
export TRANSFORMERS_CACHE=$CACHE_DIR # Add this for extra robustness

TRITON_CACHE_DIR=$TMPDIR/triton_cache
mkdir -p $TRITON_CACHE_DIR # Ensure the directory exists
export TRITON_CACHE_DIR=$TRITON_CACHE_DIR # ADD THIS LINE
 
time python3 rl_training.py

EXIT_STATUS=$?
echo "Processing finished with exit status: $EXIT_STATUS"

deactivate
exit $EXIT_STATUS